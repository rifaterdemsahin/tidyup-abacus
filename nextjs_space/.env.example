# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# On Fly.io use a Fly Postgres cluster or Neon.tech.
DATABASE_URL="postgresql://user:password@host:5432/dbname?connect_timeout=15"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-random-32-char-string"

# Full public URL of your running app (no trailing slash).
# On Fly.io: https://<app-name>.fly.dev
NEXTAUTH_URL="https://tidyup-abacus.fly.dev"

# ── AWS S3 (item photo uploads) ───────────────────────────────────────────────
AWS_REGION="us-east-1"
AWS_BUCKET_NAME="your-bucket-name"
AWS_FOLDER_PREFIX="uploads/"

# AWS credentials — use IAM role on Fly (preferred) or explicit keys.
# If using explicit keys, add these:
# AWS_ACCESS_KEY_ID="AKIA..."
# AWS_SECRET_ACCESS_KEY="..."
